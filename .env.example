# Appwrite Configuration
VITE_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_project_id
VITE_APPWRITE_DATABASE_ID=your_database_id
VITE_APPWRITE_BUCKET_ID=your_bucket_id

# Admin Auth — RECOMMENDED: real Appwrite Auth (session-based, secure)
# 1. Create an admin user in Appwrite Console → Auth
# 2. Set the email below to that user's email address
VITE_ADMIN_EMAIL=admin@example.com

# Admin Password Hash (SHA-256) — LEGACY fallback, used only when VITE_ADMIN_EMAIL
# is unset or the Appwrite user doesn't exist yet. Insecure on its own; migrate
# to VITE_ADMIN_EMAIL above as soon as your Appwrite admin user is created.
# Generate hash: echo -n "your_password" | shasum -a 256
VITE_ADMIN_PASSWORD_HASH=your_sha256_hash_here

# Note: Create a .env file with your actual values
# Never commit .env to version control
