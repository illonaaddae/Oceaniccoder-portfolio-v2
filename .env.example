# Appwrite Configuration
VITE_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_project_id
VITE_APPWRITE_DATABASE_ID=your_database_id
VITE_APPWRITE_BUCKET_ID=your_bucket_id

# Admin Auth — Appwrite Auth (session-based, server-side verified)
# 1. Create an admin user in Appwrite Console → Auth
# 2. Set the email below to that user's email address
# The legacy SHA-256 hash fallback (VITE_ADMIN_PASSWORD_HASH) was removed —
# it exposed the password hash in the client bundle.
VITE_ADMIN_EMAIL=admin@example.com

# Netlify Functions base URL (required for Azure-served deploys)
# Set this to your Netlify site URL so /api/* calls route to Netlify functions.
# Example: https://oceaniccoder-portfolio-v2.netlify.app
# Leave empty on Netlify-served deploys (calls stay relative).
VITE_FUNCTIONS_BASE_URL=

# Note: Create a .env file with your actual values
# Never commit .env to version control
